---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import PageEditor from '../../components/admin/PageEditor';
---
<AdminLayout title="Home" activeSection="home">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-adm-ink">Home</h1>
        <p class="text-adm-ink-muted mt-1 text-sm">Blocos de conteúdo da página inicial. Clique em um bloco para expandir e editar seus campos.</p>
    </div>
    <PageEditor client:load dataPath="src/data/page.json" isHome={true} pageLabel="Home — blocos" />
</AdminLayout>
