---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import SiteConfigEditor from '../../components/admin/SiteConfigEditor';
---
<AdminLayout title="Dados da clínica" activeSection="dados-clinica">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-adm-ink">Dados da clínica</h1>
        <p class="text-adm-ink-muted mt-1 text-sm">Nome, contato, horários e redes sociais — usados em todo o site.</p>
    </div>
    <SiteConfigEditor client:load />
</AdminLayout>
